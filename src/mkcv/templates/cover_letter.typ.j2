// Cover letter template — generated by mkcv
// Theme: {{ theme }}

#set page(
  paper: "{{ page_size | default('us-letter') }}",
  margin: (
    top: {{ margin_top | default('1.2in') }},
    bottom: {{ margin_bottom | default('1in') }},
    left: {{ margin_left | default('1in') }},
    right: {{ margin_right | default('1in') }},
  ),
)

#set text(
  font: "{{ font | default('Source Sans Pro') }}",
  size: {{ font_size | default('11pt') }},
  lang: "en",
)

#set par(
  justify: true,
  leading: {{ line_spacing | default('0.7em') }},
)

// Header — candidate name
#align(center)[
  #text(size: {{ name_size | default('16pt') }}, weight: "bold")[{{ candidate_name }}]
]

#v(0.3in)

// Date
#align(right)[
  #datetime.today().display("[month repr:long] [day], [year]")
]

#v(0.15in)

// Company and role reference
{% if show_company %}
#text(weight: "bold")[{{ company }}] \
{% endif %}
{% if show_role %}
_Re: {{ role_title }}_
{% endif %}
{% if show_company or show_role %}

#v(0.2in)
{% endif %}

// Salutation
{{ salutation }}

#v(0.1in)

// Opening paragraph
{{ opening_paragraph }}

{% for paragraph in body_paragraphs %}
#v(0.08in)

{{ paragraph }}

{% endfor %}
#v(0.08in)

{{ closing_paragraph }}

#v(0.25in)

// Sign-off
{{ sign_off }} \
{{ candidate_name }}

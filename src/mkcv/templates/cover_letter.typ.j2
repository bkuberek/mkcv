// Cover letter template — generated by mkcv
// Theme: {{ theme }}

#set page(
  paper: "us-letter",
  margin: (top: 1.2in, bottom: 1in, left: 1in, right: 1in),
)

#set text(
  font: "Source Sans Pro",
  size: 11pt,
  lang: "en",
)

#set par(
  justify: true,
  leading: 0.7em,
)

// Header — candidate name
#align(center)[
  #text(size: 16pt, weight: "bold")[{{ candidate_name }}]
]

#v(0.3in)

// Date
#align(right)[
  #datetime.today().display("[month repr:long] [day], [year]")
]

#v(0.15in)

// Company and role reference
#text(weight: "bold")[{{ company }}] \
_Re: {{ role_title }}_

#v(0.2in)

// Salutation
{{ salutation }}

#v(0.1in)

// Opening paragraph
{{ opening_paragraph }}

{% for paragraph in body_paragraphs %}
#v(0.08in)

{{ paragraph }}

{% endfor %}
#v(0.08in)

{{ closing_paragraph }}

#v(0.25in)

// Sign-off
{{ sign_off }} \
{{ candidate_name }}
